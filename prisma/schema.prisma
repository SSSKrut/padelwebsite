// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Перечисление для ролей
enum Role {
  SUPER_ADMIN
  UNVERIFIED_USER
  USER
  ADMIN
}

// Перечисление для статусов ивентов
enum EventStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum MatchTableMode {
  AUTO_COURTS
  MANUAL_ELO
}

enum MatchTableStatus {
  DRAFT
  OPEN
  CONFIRMED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  createdAt    DateTime @default(now())

  role Role @default(UNVERIFIED_USER)
  elo  Int  @default(1000)

  achievements         UserAchievement[]
  registrations        EventRegistration[]
  waitlistEntries      EventWaitlist[]
  eventScores          EventScore[]
  courtAssignments     EventCourtAssignment[]
  manualEloEntries     EventManualElo[]
  tokens               VerificationToken[]
  premiumSubscriptions PremiumSubscription[]  @relation("PremiumUser")
  premiumGrantedBy     PremiumSubscription[]  @relation("PremiumGranter")
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id                    String           @id @default(uuid())
  title                 String
  description           String?
  date                  DateTime
  endDate               DateTime?
  location              String?
  status                EventStatus      @default(DRAFT)
  publishAt             DateTime?
  reminderSentAt        DateTime?
  maxParticipants       Int              @default(16)
  price                 String?
  disclaimer            String?
  createdAt             DateTime         @default(now())
  matchTableStatus      MatchTableStatus @default(DRAFT)
  matchTableMode        MatchTableMode @default(AUTO_COURTS)
  matchTableGeneratedAt DateTime?
  matchTableConfirmedAt DateTime?

  participants     EventRegistration[]
  waitlist         EventWaitlist[]
  scores           EventScore[]
  courtAssignments EventCourtAssignment[]
  matches          EventMatch[]
  manualEloEntries EventManualElo[]
}

model PremiumSubscription {
  id        String    @id @default(uuid())
  grantedAt DateTime  @default(now())
  revokedAt DateTime?

  userId String
  user   User   @relation("PremiumUser", fields: [userId], references: [id], onDelete: Cascade)

  grantedById String
  grantedBy   User   @relation("PremiumGranter", fields: [grantedById], references: [id], onDelete: Cascade)
}

model EventRegistration {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventWaitlist {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventScore {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  previousElo Int
  newElo      Int

  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventCourtAssignment {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  eventId     String
  userId      String
  courtNumber Int

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, courtNumber])
}

model EventMatch {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  eventId        String
  courtNumber    Int
  round          Int
  pair1Player1Id String
  pair1Player2Id String
  pair2Player1Id String
  pair2Player2Id String
  score1         Int?
  score2         Int?
  updatedById    String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, courtNumber, round])
}

model EventManualElo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  eventId   String
  userId    String
  previousElo Int?
  newElo    Int
  isWinner  Boolean  @default(false)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Achievement {
  id          String  @id @default(uuid())
  title       String  @unique
  description String?
  icon        String?

  users UserAchievement[]
}

model UserAchievement {
  id          String   @id @default(uuid())
  dateAwarded DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
}

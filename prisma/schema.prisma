// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Перечисление для ролей
enum Role {
  SUPER_ADMIN
  UNVERIFIED_USER
  USER
  ADMIN
}

// Перечисление для статусов ивентов
enum EventStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum MatchTableMode {
  AUTO_COURTS
  MANUAL_ELO
}

enum MatchTableStatus {
  DRAFT
  OPEN
  CONFIRMED
}

enum EventMatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ABANDONED
  WALKOVER
  NO_CONTEST
}

enum EventParticipantStatus {
  ACTIVE
  WITHDRAWN
  DNF
}

enum EventScoreLineStatus {
  VALID
  VOIDED
}

enum RatingSystem {
  ELO
}

enum RatingReason {
  MATCH
  EVENT_FINAL
  MANUAL
  IMPORT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  createdAt    DateTime @default(now())

  role Role @default(UNVERIFIED_USER)
  elo  Int  @default(1000)

  achievements         UserAchievement[]
  registrations        EventRegistration[]
  waitlistEntries      EventWaitlist[]
  eventScores          EventScore[]
  courtAssignments     EventCourtAssignment[]
  manualEloEntries     EventManualElo[]
  tokens               VerificationToken[]
  premiumSubscriptions PremiumSubscription[]  @relation("PremiumUser")
  premiumGrantedBy     PremiumSubscription[]  @relation("PremiumGranter")
  eventCancellations   EventCancellation[]
  matchParticipants    EventMatchParticipant[] @relation("MatchParticipantUser")
  matchParticipantReplacements EventMatchParticipant[] @relation("MatchParticipantReplacement")
  scoreLinesEntered    EventScoreLine[] @relation("ScoreLineEnteredBy")
  ratingChanges        EventRatingChange[]
  matchUpdates         EventMatch[] @relation("EventMatchUpdatedBy")
  ratingSettings       UserRatingSettings[]
  emailPreferences     UserEmailPreferences?
  weeklyRatings        UserWeeklyRating[]
}

model UserRatingSettings {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  ratingSystem RatingSystem @default(ELO)
  kFactor      Int      @default(40)
  notes        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ratingSystem])
}

model UserEmailPreferences {
  id                      String   @id @default(uuid())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  userId                  String   @unique
  welcome                 Boolean  @default(true)
  emailVerification       Boolean  @default(true)
  passwordReset           Boolean  @default(true)
  accountApproved         Boolean  @default(true)
  eventRegistration       Boolean  @default(true)
  eventWaitlist           Boolean  @default(true)
  eventWaitlistPromotion  Boolean  @default(true)
  eventCancelled          Boolean  @default(true)
  eventReminder           Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserWeeklyRating {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  weekStart DateTime
  rating    Int
  rank      Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart, rank])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Competition {
  id          String   @id @default(uuid())
  name        String
  description String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())

  events Event[]
}

model Event {
  id                    String           @id @default(uuid())
  title                 String
  description           String?
  date                  DateTime
  endDate               DateTime?
  location              String?
  status                EventStatus      @default(DRAFT)
  publishAt             DateTime?
  reminderSentAt        DateTime?
  maxParticipants       Int              @default(16)
  price                 String?
  disclaimer            String?
  createdAt             DateTime         @default(now())
  competitionId         String?
  formatId              String?
  formatConfig          Json?
  matchTableStatus      MatchTableStatus @default(DRAFT)
  matchTableMode        MatchTableMode @default(AUTO_COURTS)
  matchTableGeneratedAt DateTime?
  matchTableConfirmedAt DateTime?

  participants     EventRegistration[]
  waitlist         EventWaitlist[]
  scores           EventScore[]
  courtAssignments EventCourtAssignment[]
  matches          EventMatch[]
  manualEloEntries EventManualElo[]
  cancellation     EventCancellation?
  competition      Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  format           EventFormat? @relation(fields: [formatId], references: [id], onDelete: SetNull)
  ratingChanges    EventRatingChange[]
  courtOverrides   EventCourtOverride[]
}

model EventFormat {
  id          String   @id @default(uuid())
  name        String
  description String?
  strategyKey String
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events Event[]
}

model PremiumSubscription {
  id        String    @id @default(uuid())
  grantedAt DateTime  @default(now())
  revokedAt DateTime?

  userId String
  user   User   @relation("PremiumUser", fields: [userId], references: [id], onDelete: Cascade)

  grantedById String
  grantedBy   User   @relation("PremiumGranter", fields: [grantedById], references: [id], onDelete: Cascade)
}

model EventRegistration {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventWaitlist {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventScore {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  previousElo Int
  newElo      Int

  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventCourtAssignment {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  eventId     String
  userId      String
  courtNumber Int

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, courtNumber])
}

model EventCourtOverride {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  eventId     String
  courtNumber Int
  isManual    Boolean  @default(true)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, courtNumber])
  @@index([eventId, courtNumber])
}

model EventMatch {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  eventId        String
  courtNumber    Int
  round          Int
  status         EventMatchStatus @default(SCHEDULED)
  startedAt      DateTime?
  endedAt        DateTime?
  lockedByAdmin  Boolean @default(false)
  pair1Player1Id String
  pair1Player2Id String
  pair2Player1Id String
  pair2Player2Id String
  score1         Int?
  score2         Int?
  updatedById    String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  updatedBy User? @relation("EventMatchUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sides EventMatchSide[]
  scoreLines EventScoreLine[]
  ratingChanges EventRatingChange[]

  @@index([eventId, courtNumber, round])
}

model EventMatchSide {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  matchId   String
  sideIndex Int
  name      String?

  match        EventMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  participants EventMatchParticipant[]

  @@unique([matchId, sideIndex])
}

model EventMatchParticipant {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  matchSideId  String
  userId       String
  seatIndex    Int?
  status       EventParticipantStatus @default(ACTIVE)
  notes        String?
  replacedById String?

  matchSide  EventMatchSide @relation(fields: [matchSideId], references: [id], onDelete: Cascade)
  user       User           @relation("MatchParticipantUser", fields: [userId], references: [id], onDelete: Cascade)
  replacedBy User?          @relation("MatchParticipantReplacement", fields: [replacedById], references: [id], onDelete: SetNull)

  @@unique([matchSideId, userId])
  @@index([userId])
}

model EventScoreLine {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  matchId     String
  sequence    Int
  scoreSide1  Int?
  scoreSide2  Int?
  status      EventScoreLineStatus @default(VALID)
  isCounted   Boolean @default(true)
  enteredById String?
  enteredAt   DateTime?
  notes       String?

  match     EventMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  enteredBy User?      @relation("ScoreLineEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)

  @@unique([matchId, sequence])
  @@index([matchId, status])
}

model EventRatingChange {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  appliedAt    DateTime?
  eventId      String
  userId       String
  matchId      String?
  ratingSystem RatingSystem @default(ELO)
  reason       RatingReason @default(MATCH)
  before       Int
  delta        Int
  after        Int
  notes        String?

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  match EventMatch? @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([eventId, userId])
  @@index([matchId])
}

model EventManualElo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  eventId   String
  userId    String
  previousElo Int?
  newElo    Int
  isWinner  Boolean  @default(false)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventCancellation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  message   String

  eventId       String @unique
  cancelledById String

  event       Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  cancelledBy User  @relation(fields: [cancelledById], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String  @id @default(uuid())
  title       String  @unique
  description String?
  icon        String?

  users UserAchievement[]
}

model UserAchievement {
  id          String   @id @default(uuid())
  dateAwarded DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
}
